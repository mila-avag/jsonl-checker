        "properties": {
          "rubric_id": { "type": "string" },
          "test_name": { "type": "string" },
          "behavior": { "type": "string" }
        }
      }
    },
    "gate_pass": { "type": "boolean" },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "reasoning": { "type": "string" }
  }
}
