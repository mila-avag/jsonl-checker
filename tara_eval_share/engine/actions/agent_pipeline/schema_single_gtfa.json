          "approach",
          "final_outcome"
        ],
        "additionalProperties": false,
        "properties": {
          "approach": {
            "type": "string"
          },
          "final_outcome": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "string",
