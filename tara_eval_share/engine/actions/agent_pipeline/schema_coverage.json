{
  "type": "object",
  "required": ["item_id", "task_id", "item_type", "verifier_verdict", "missing_criteria", "confidence", "reasoning"],
  "additionalProperties": false,
  "properties": {
    "item_id": { "type": "string" },
    "task_id": { "type": "string" },
    "item_type": { "type": "string", "enum": ["coverage_check"] },
    "verifier_verdict": { "type": "string", "enum": ["complete", "gaps_found"] },
    "missing_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement", "criticality", "description"],
        "additionalProperties": false,
        "properties": {
          "requirement": { "type": "string" },
          "criticality": { "type": "string", "enum": ["critical", "non_critical"] },
          "description": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "reasoning": { "type": "string" }
  }
}
